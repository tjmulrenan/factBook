{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: publish-book.spec (Chromium)",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": [
        "test",
        "tests/publish-book.spec.js",
        "-g", "publish paperback from DOY",
        "--project=chromium"
      ],
      "cwd": "${workspaceFolder}/publisher-bot",
      "env": {
        "DOY": "292"                // set your DOY here when practicing
      },
      "console": "integratedTerminal",
      "runtimeArgs": ["--inspect-brk"], // let VS Code attach before running
      "timeout": 0,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
